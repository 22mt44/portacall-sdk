{
	"name": "portacall-sdk",
	"private": true,
	"packageManager": "bun@1.3.4",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "turbo run build",
		"test": "turbo run test",
		"typecheck": "turbo run typecheck",
		"lint": "turbo run lint && biome check package.json README.md turbo.json .github/workflows/ci.yml",
		"check": "bun run test && bun run typecheck && bun run lint",
		"release:client:dry": "npm publish --workspace @portacall/client --dry-run",
		"release:client": "npm publish --workspace @portacall/client",
		"release:proxy:dry": "npm publish --workspace @portacall/proxy --dry-run",
		"release:proxy": "npm publish --workspace @portacall/proxy"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "^1.3.11",
		"hono": "^4.12.9",
		"turbo": "^2.5.8",
		"tsdown": "^0.21.4",
		"typescript": "^5.9.3"
	}
}
