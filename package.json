{
	"name": "@portacall/sdk",
	"version": "0.1.0",
	"description": "Minimal server-side SDK for calling a Portacall agent.",
	"license": "MIT",
	"type": "module",
	"packageManager": "bun@1.3.4",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"sideEffects": false,
	"homepage": "https://github.com/22mt44/portacall-sdk#readme",
	"bugs": {
		"url": "https://github.com/22mt44/portacall-sdk/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/22mt44/portacall-sdk.git"
	},
	"keywords": [
		"ai",
		"agent",
		"sdk",
		"llm",
		"portacall"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"default": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"default": "./dist/index.cjs"
			}
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown src/index.ts --format esm,cjs --dts",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src package.json tsconfig.json README.md .github/workflows/ci.yml",
		"check": "bun run test && bun run typecheck && bun run lint",
		"release:dry": "npm publish --dry-run",
		"release": "npm publish",
		"prepack": "bun run build",
		"prepublishOnly": "bun run check && bun run build"
	},
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "^1.3.11",
		"tsdown": "^0.21.4",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"hono": "^4.12.9"
	}
}
