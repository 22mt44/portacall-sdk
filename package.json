{
	"name": "@portacall/sdk",
	"version": "0.1.0",
	"description": "Minimal SDK for Portacall server and browser integrations.",
	"license": "MIT",
	"type": "module",
	"packageManager": "bun@1.3.4",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"homepage": "https://github.com/22mt44/portacall-sdk#readme",
	"bugs": {
		"url": "https://github.com/22mt44/portacall-sdk/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/22mt44/portacall-sdk.git"
	},
	"keywords": [
		"ai",
		"agent",
		"sdk",
		"llm",
		"portacall"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./client": {
			"types": "./dist/client.d.ts",
			"import": "./dist/client.mjs",
			"require": "./dist/client.cjs"
		},
		"./hono": {
			"types": "./dist/hono.d.ts",
			"import": "./dist/hono.mjs",
			"require": "./dist/hono.cjs"
		},
		"./express": {
			"types": "./dist/express.d.ts",
			"import": "./dist/express.mjs",
			"require": "./dist/express.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun run build:js && bun run build:types",
		"build:js": "tsdown",
		"build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src package.json tsconfig.json tsdown.config.ts README.md .github/workflows/ci.yml",
		"check": "bun run test && bun run typecheck && bun run lint",
		"release:dry": "npm publish --dry-run",
		"release": "npm publish",
		"prepack": "bun run build",
		"prepublishOnly": "bun run check && bun run build"
	},
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/bun": "^1.3.11",
		"hono": "^4.12.9",
		"tsdown": "^0.21.4",
		"typescript": "^5.9.3"
	}
}
