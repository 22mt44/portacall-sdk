{
	"name": "@portacall/server",
	"version": "0.1.0",
	"description": "Server SDK for Portacall routes, tool sync, and webhook execution.",
	"license": "MIT",
	"type": "module",
	"packageManager": "bun@1.3.4",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./hono": {
			"types": "./dist/hono.d.ts",
			"import": "./dist/hono.mjs",
			"require": "./dist/hono.cjs"
		},
		"./express": {
			"types": "./dist/express.d.ts",
			"import": "./dist/express.mjs",
			"require": "./dist/express.cjs"
		},
		"./auth/better-auth": {
			"types": "./dist/auth/better-auth.d.ts",
			"import": "./dist/auth/better-auth.mjs",
			"require": "./dist/auth/better-auth.cjs"
		},
		"./auth/authjs": {
			"types": "./dist/auth/authjs.d.ts",
			"import": "./dist/auth/authjs.mjs",
			"require": "./dist/auth/authjs.cjs"
		}
	},
	"sideEffects": false,
	"homepage": "https://github.com/22mt44/portacall-sdk/tree/main/packages/server#readme",
	"bugs": {
		"url": "https://github.com/22mt44/portacall-sdk/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/22mt44/portacall-sdk.git",
		"directory": "packages/server"
	},
	"keywords": [
		"ai",
		"agent",
		"sdk",
		"llm",
		"portacall",
		"server",
		"backend"
	],
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun run build:js && bun run build:types",
		"build:js": "tsdown",
		"build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --declaration --outDir dist",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src package.json tsconfig.json tsconfig.build.json tsdown.config.ts README.md",
		"check": "bun run test && bun run typecheck && bun run lint",
		"prepack": "bun run build",
		"prepublishOnly": "bun run check && bun run build"
	},
	"publishConfig": {
		"access": "public"
	}
}
