{
	"name": "@portacall/proxy",
	"version": "0.1.0",
	"description": "Backend proxy SDK for Portacall routes.",
	"license": "MIT",
	"type": "module",
	"packageManager": "bun@1.3.4",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"sideEffects": false,
	"homepage": "https://github.com/22mt44/portacall-sdk/tree/main/packages/proxy#readme",
	"bugs": {
		"url": "https://github.com/22mt44/portacall-sdk/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/22mt44/portacall-sdk.git",
		"directory": "packages/proxy"
	},
	"keywords": [
		"ai",
		"agent",
		"sdk",
		"llm",
		"portacall",
		"proxy",
		"backend"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./adapters/express": {
			"types": "./dist/adapters/express.d.ts",
			"import": "./dist/adapters/express.mjs",
			"require": "./dist/adapters/express.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun run build:js && bun run build:types",
		"build:js": "tsdown",
		"build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --declaration --outDir dist",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src package.json tsconfig.json tsconfig.build.json tsdown.config.ts README.md",
		"check": "bun run test && bun run typecheck && bun run lint",
		"prepack": "bun run build",
		"prepublishOnly": "bun run check && bun run build"
	},
	"publishConfig": {
		"access": "public"
	}
}
