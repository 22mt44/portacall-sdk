{
	"name": "@portacall/react",
	"version": "0.1.0",
	"description": "React adapter for the Portacall client SDK.",
	"license": "MIT",
	"type": "module",
	"packageManager": "bun@1.3.4",
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		}
	},
	"sideEffects": false,
	"homepage": "https://github.com/22mt44/portacall-sdk/tree/main/packages/react#readme",
	"bugs": {
		"url": "https://github.com/22mt44/portacall-sdk/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/22mt44/portacall-sdk.git",
		"directory": "packages/react"
	},
	"keywords": [
		"ai",
		"agent",
		"sdk",
		"llm",
		"portacall",
		"client",
		"react"
	],
	"files": [
		"dist"
	],
	"scripts": {
		"build": "bun run build:js && bun run build:types",
		"build:js": "tsdown",
		"build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly --declaration --outDir dist",
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"lint": "biome check src package.json tsconfig.json tsconfig.build.json tsdown.config.ts README.md",
		"check": "bun run test && bun run typecheck && bun run lint",
		"prepack": "bun run build",
		"prepublishOnly": "bun run check && bun run build"
	},
	"peerDependencies": {
		"@portacall/client": "^0.1.0",
		"react": ">=18"
	},
	"devDependencies": {
		"@portacall/client": "workspace:*",
		"@types/react": "^19.2.2",
		"@types/react-dom": "^19.2.2",
		"@types/react-test-renderer": "^19.1.0",
		"react": "^19.2.0",
		"react-dom": "^19.2.0",
		"react-test-renderer": "^19.2.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
